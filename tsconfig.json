{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@zerostorage/api": ["packages/api/src"],
      "@zerostorage/sdk": ["packages/sdk/src"],
      "@zerostorage/dashboard": ["packages/dashboard/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
